{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "assignAutomerge": true,
  "ignoreUnstable": true,
  "reviewers": [
    "eudaldgr"
  ],
  "packageRules": [
    {
      "groupName": "github-actions",
      "matchManagers": [
        "github-actions"
      ],
      "automerge": true
    },
    {
      "matchDatasources": [
        "github-releases",
        "github-tags"
      ],
      "matchPackageNames": [
        "chainguard-dev/melange",
        "chainguard-dev/apko"
      ],
      "groupName": "wolfi-tools"
    },
    {
      "matchPackageNames": [
        "miniupnp/miniupnp"
      ],
      "versioning": "regex:^(?:miniupnpc_)?(?<major>\\d+)[._](?<minor>\\d+)[._](?<patch>\\d+)$"
    },
    {
      "matchPackageNames": [
        "lightningnetwork/lnd"
      ],
      "extractVersion": "^v(?<version>.*)$",
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)(?:[_-](?<prerelease>.*))?$"
    },
    {
      "matchPackageNames": [
        "bitcoinknots/bitcoin"
      ],
      "extractVersion": "^v(?<version>.*)$",
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?:knots|\\.)(?<patch>\\d+)$"
    },
    {
      "matchPackageNames": [
        "AdguardTeam/AdGuardHome",
        "arvidn/libtorrent",
        "seerr-team/seerr",
        "VueTorrent/VueTorrent",
        "vaultwarden/web-vault"
      ],
      "extractVersion": "^v(?<version>.*)$"
    },
    {
      "matchPackageNames": [
        "Lidarr/Lidarr",
        "Prowlarr/Prowlarr",
        "Radarr/Radarr",
        "Readarr/Readarr",
        "Sonarr/Sonarr",
        "Whisparr/Whisparr"
      ],
      "extractVersion": "^v?(?<version>.*)$",
      "versioning": "regex:^v?(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)\\.(?<build>\\d+)$"
    },
    {
      "matchPackageNames": [
        "qbittorrent/qBittorrent"
      ],
      "extractVersion": "^release-(?<version>.*)$"
    },
    {
      "matchDatasources": [
        "custom.plex"
      ],
      "extractVersion": "^(?<version>\\d+\\.\\d+\\.\\d+\\.\\d+)(?:-.+)?$",
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)\\.(?<build>\\d+)$"
    },
    {
      "matchPackageNames": [
        "rocksdb-10"
      ],
      "allowedVersions": "<11.0.0"
    }
  ],
  "customDatasources": {
    "plex": {
      "defaultRegistryUrlTemplate": "https://plex.tv/api/downloads/5.json",
      "format": "json",
      "transformTemplates": [
        "{ \"releases\": [{ \"version\": computer.Linux.version }], \"homepage\": \"https://www.plex.tv/media-server-downloads/\" }"
      ]
    }
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update Melange package.version and reset epoch",
      "managerFilePatterns": [
        "/(^|/)melange\\.yaml$/"
      ],
      "matchStrings": [
        "(?<indentation>[ \\t]+)version:\\s*[\"']?(?<currentValue>[^\\s#\\n\"']+)[\"']?\\s*# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\n[ \\t]+epoch:\\s*\\d+"
      ],
      "autoReplaceStringTemplate": "{{{indentation}}}version: {{{newValue}}} # renovate: datasource={{{datasource}}} depName={{{depName}}}\n{{{indentation}}}epoch: 0"
    },
    {
      "customType": "regex",
      "description": "Update Tor package.version and reset epoch",
      "managerFilePatterns": [
        "/^tor\\/melange\\.yaml$/"
      ],
      "matchStrings": [
        "(?<indentation>[ \\t]+)version:\\s*[\"']?(?<currentValue>[^\\s#\\n\"']+)[\"']?\\s*# renovate: datasource=gitlab-tags depName=tpo/core/tor registryUrl=https://gitlab\\.torproject\\.org extractVersion=\\^tor-\\(\\?<version>\\.\\*\\)\\$\\n[ \\t]+epoch:\\s*\\d+"
      ],
      "datasourceTemplate": "gitlab-tags",
      "depNameTemplate": "tpo/core/tor",
      "registryUrlTemplate": "https://gitlab.torproject.org",
      "extractVersionTemplate": "^tor-(?<version>.*)$",
      "autoReplaceStringTemplate": "{{{indentation}}}version: {{{newValue}}} # renovate: datasource=gitlab-tags depName=tpo/core/tor registryUrl=https://gitlab.torproject.org extractVersion=^tor-(?<version>.*)$\n{{{indentation}}}epoch: 0"
    },
    {
      "customType": "regex",
      "description": "Update Melange variable versions",
      "managerFilePatterns": [
        "/(^|/)melange\\.yaml$/"
      ],
      "matchStrings": [
        "(?<prefix>^|\\n)(?<indentation>[ \\t]+)(?<varName>[A-Za-z0-9_.-]+-version):\\s*[\"']?(?<currentValue>[^\\s#\\n\"']+)[\"']?\\s*# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: registryUrl=(?<registryUrl>\\S+))?(?: extractVersion=(?<extractVersion>\\S+))?(?: versioning=(?<versioning>\\S+))?"
      ]
    },
    {
      "customType": "regex",
      "description": "Update pinned MELANGE_VERSION and APKO_VERSION in build workflow",
      "managerFilePatterns": [
        "/^\\.github/workflows/build\\.yaml$/"
      ],
      "matchStrings": [
        "(?<depNameTemplate>MELANGE|APKO)_VERSION: (?<currentValue>\\S+) # renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)"
      ]
    }
  ]
}
