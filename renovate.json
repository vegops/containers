{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "assignAutomerge": true,
  "ignoreUnstable": true,
  "reviewers": [
    "eudaldgr"
  ],
  "packageRules": [
    {
      "groupName": "github-actions",
      "matchManagers": [
        "github-actions"
      ],
      "automerge": true
    },
    {
      "matchDatasources": [
        "github-releases",
        "github-tags"
      ],
      "matchPackageNames": [
        "chainguard-dev/melange",
        "chainguard-dev/apko"
      ],
      "groupName": "wolfi-tools"
    },
    {
      "matchPackageNames": [
        "miniupnp/miniupnp"
      ],
      "versioning": "regex:^(?:miniupnpc_)?(?<major>\\d+)[._](?<minor>\\d+)[._](?<patch>\\d+)$"
    },
    {
      "matchPackageNames": [
        "lightningnetwork/lnd"
      ],
      "extractVersion": "^v(?<version>.*)$",
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)(?:[_-](?<prerelease>.*))?$"
    },
    {
      "matchPackageNames": [
        "bitcoinknots/bitcoin"
      ],
      "extractVersion": "^v(?<version>.*)$",
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?:knots|\\.)(?<patch>\\d+)$"
    },
    {
      "matchPackageNames": [
        "AdguardTeam/AdGuardHome",
        "arvidn/libtorrent",
        "seerr-team/seerr",
        "VueTorrent/VueTorrent",
        "vaultwarden/web-vault"
      ],
      "extractVersion": "^v(?<version>.*)$"
    },
    {
      "matchPackageNames": [
        "qbittorrent/qBittorrent"
      ],
      "extractVersion": "^release-(?<version>.*)$"
    },
    {
      "matchDatasources": [
        "custom.plex"
      ],
      "extractVersion": "^(?<version>\\d+\\.\\d+\\.\\d+\\.\\d+)(?:-.+)?$",
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)\\.(?<build>\\d+)$"
    },
    {
      "matchPackageNames": [
        "rocksdb-10"
      ],
      "allowedVersions": "<11.0.0"
    }
  ],
  "customDatasources": {
    "plex": {
      "defaultRegistryUrlTemplate": "https://plex.tv/api/downloads/5.json",
      "format": "json",
      "transformTemplates": [
        "{ \"releases\": [{ \"version\": computer.Linux.version }], \"homepage\": \"https://www.plex.tv/media-server-downloads/\" }"
      ]
    }
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Comment-based updates for melange.yaml (centralized logic)",
      "managerFilePatterns": [
        "/(^|/)melange\\.yaml$/"
      ],
      "matchStrings": [
        "(?<part>version|tag):\\s*[\"']?(?<currentValue>[^\\s#\\n\"']+)[\"']?\\s*# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)"
      ]
    },
    {
      "customType": "regex",
      "description": "Automatic updates for simple melange.yaml files",
      "managerFilePatterns": [
        "/(^|/)melange\\.yaml$/"
      ],
      "matchStrings": [
        "version:\\s*[\"']?(?<currentValue>[^\\s#\\n\"']+)[\"']?[\\s\\S]*?github:\\s*identifier:\\s*[\"']?(?<depName>[^\\s\\n#\"']+)[\"']?"
      ],
      "datasourceTemplate": "github-tags",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "Update pinned MELANGE_VERSION and APKO_VERSION in build workflow",
      "managerFilePatterns": [
        "/^\\.github/workflows/build\\.yaml$/"
      ],
      "matchStrings": [
        "(?<depNameTemplate>MELANGE|APKO)_VERSION: (?<currentValue>\\S+) # renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)"
      ]
    }
  ]
}